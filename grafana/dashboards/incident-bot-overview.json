{
  "uid": "incident-bot-overview",
  "title": "Incident Bot - Overview",
  "tags": ["incident-bot", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 7,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Active Incidents (Total)",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(incident_bot_incidents_active)" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Active Incidents (by severity)",
      "id": 2,
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "incident_bot_incidents_active" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Host CPU %",
      "id": 7,
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"node\",mode=\"idle\"}[5m])) * 100)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Host Memory %",
      "id": 8,
      "gridPos": { "x": 6, "y": 4, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"node\"} / node_memory_MemTotal_bytes{job=\"node\"})) * 100"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Host Disk % (max usage) — filtered",
      "id": 9,
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "max((1 - (node_filesystem_avail_bytes{job=\"node\",fstype!~\"tmpfs|overlay|squashfs\",mountpoint!~\"^/(run/desktop|mnt/host|usr/lib/wsl|parent-distro).*\"} / node_filesystem_size_bytes{job=\"node\",fstype!~\"tmpfs|overlay|squashfs\",mountpoint!~\"^/(run/desktop|mnt/host|usr/lib/wsl|parent-distro).*\"})) * 100)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 1 },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
  "type": "timeseries",
  "title": "Host Disk % (top mounts) — debug",
  "id": 109,
  "gridPos": { "x": 0, "y": 67, "w": 24, "h": 8 },
  "datasource": { "type": "prometheus", "uid": "prometheus" },
  "targets": [
    {
      "refId": "A",
      "expr": "topk(10, (1 - (node_filesystem_avail_bytes{job=\"node\",fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{job=\"node\",fstype!~\"tmpfs|overlay|squashfs\"})) * 100)",
      "legendFormat": "{{mountpoint}} ({{fstype}})"
    }
  ],
  "fieldConfig": {
    "defaults": { "unit": "percent", "decimals": 1 },
    "overrides": []
  },
  "options": {
    "legend": { "showLegend": true, "placement": "bottom" },
    "tooltip": { "mode": "multi" }
  }
},
    {
      "type": "stat",
      "title": "Host Load / CPU (15m)",
      "id": 10,
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "node_load15{job=\"node\"} / count without (cpu, mode) (node_cpu_seconds_total{job=\"node\",mode=\"idle\"})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "Webhook Requests / min (5m rate)",
      "id": 3,
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (source, status) (rate(incident_bot_webhook_requests_total[5m])) * 60",
          "legendFormat": "{{source}} / {{status}}"
        }
      ],
      "options": {
        "legend": { "showLegend": true, "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "timeseries",
      "title": "Runbooks / min (5m rate)",
      "id": 4,
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (runbook, status, triggered_by) (rate(incident_bot_runbooks_executed_total[5m])) * 60",
          "legendFormat": "{{runbook}} / {{status}} / {{triggered_by}}"
        }
      ],
      "options": {
        "legend": { "showLegend": true, "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "timeseries",
      "title": "Top 5 Containers CPU %",
      "id": 11,
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, sum by (service) ( rate(container_cpu_usage_seconds_total{job=\"cadvisor\", cpu=\"total\", id=~\"^/docker/[0-9a-f]{64}$\"}[5m]) * on(id) group_left(service) max by (id, service) ( label_replace( max by (cadvisor_id, service) (incident_bot_container_info), \"id\", \"$1\", \"cadvisor_id\", \"(.+)\" ) ) ) * 100 )",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "options": {
        "legend": { "showLegend": true, "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "timeseries",
      "title": "Top 5 Containers Memory (MB)",
      "id": 12,
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, sum by (service) ( container_memory_working_set_bytes{job=\"cadvisor\", id=~\"^/docker/[0-9a-f]{64}$\"} * on(id) group_left(service) max by (id, service) ( label_replace( max by (cadvisor_id, service) (incident_bot_container_info), \"id\", \"$1\", \"cadvisor_id\", \"(.+)\" ) ) ) / 1024 / 1024 )",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "megabytes" }, "overrides": [] },
      "options": {
        "legend": { "showLegend": true, "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "stat",
      "title": "Total Containers CPU %",
      "id": 13,
      "gridPos": { "x": 0, "y": 23, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum( rate(container_cpu_usage_seconds_total{job=\"cadvisor\", cpu=\"total\", id=~\"^/docker/[0-9a-f]{64}$\"}[5m]) * on(id) group_left(service) max by (id, service) ( label_replace( max by (cadvisor_id, service) (incident_bot_container_info), \"id\", \"$1\", \"cadvisor_id\", \"(.+)\" ) ) ) * 100"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Containers total (cAdvisor)",
      "id": 14,
      "gridPos": { "x": 6, "y": 23, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(count by (id) (container_cpu_usage_seconds_total{job=\"cadvisor\", cpu=\"total\", id=~\"^/docker/[0-9a-f]{64}$\"}))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "Containers mapped (incident-bot)",
      "id": 15,
      "gridPos": { "x": 10, "y": 23, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "count(incident_bot_container_info)" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "barchart",
      "title": "Runbooks executed (last 1h)",
      "id": 5,
      "gridPos": { "x": 6, "y": 23, "w": 9, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (increase(incident_bot_runbooks_executed_total[1h]))",
          "legendFormat": "{{status}}"
        }
      ],
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } }
    },
    {
      "type": "timeseries",
      "title": "Webhook latency (p95, 5m)",
      "id": 6,
      "gridPos": { "x": 15, "y": 23, "w": 9, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, source) (rate(incident_bot_webhook_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{source}}"
        }
      ],
      "options": {
        "legend": { "showLegend": true, "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "timeseries",
      "title": "Audit Snapshot Duration p95 (Last 15m)",
      "id": 16,
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(audit_snapshot_duration_seconds_bucket[15m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {
        "legend": { "showLegend": true, "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "timeseries",
      "title": "Audit Snapshot Errors / s (last 15m)",
      "id": 17,
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(audit_snapshot_errors_total[15m])) by (type, block)",
          "legendFormat": "{{type}} / {{block}}"
        }
      ],
      "options": {
        "legend": { "showLegend": true, "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "timeseries",
      "title": "Audit Snapshot Cache Hits Last 15m (fresh/stale/miss)",
      "id": 18,
      "gridPos": { "x": 0, "y": 39, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(audit_snapshot_cache_hits_total[15m])) by (kind)",
          "legendFormat": "{{kind}}"
        }
      ],
      "options": {
        "legend": { "showLegend": true, "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "stat",
      "title": "Audit Snapshot Cache Hit Ratio (Last 15m)",
      "id": 19,
      "gridPos": { "x": 12, "y": 39, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(audit_snapshot_cache_hits_total{kind!=\"miss\"}[15m])) / clamp_min(sum(increase(audit_snapshot_cache_hits_total[15m])), 1)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "Audit Snapshot Block Timeouts / (Last 15m)",
      "id": 20,
      "gridPos": { "x": 0, "y": 47, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(audit_snapshot_errors_total{type=\"block_timeout\"}[15m])) by (block)",
          "legendFormat": "{{block}}"
        }
      ],
      "options": {
        "legend": { "showLegend": true, "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "timeseries",
      "title": "Audit Snapshot Mode / (full/mini/unknown) (Last 15m)",
      "id": 21,
      "gridPos": { "x": 0, "y": 55, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(audit_snapshot_mode_total[15m])) by (mode)",
          "legendFormat": "{{mode}}"
        }
      ],
      "options": {
        "legend": { "showLegend": true, "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "stat",
      "title": "Audit Snapshot % MINI (Last 15m)",
      "id": 22,
      "gridPos": { "x": 12, "y": 55, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(audit_snapshot_mode_total{mode=\"mini\"}[15m])) / clamp_min(sum(increase(audit_snapshot_mode_total[15m])), 1)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Runbooks Pending (queue)",
      "id": 23,
      "gridPos": { "x": 0, "y": 63, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "incident_bot_runbooks_pending" }],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Runbooks Running",
      "id": 24,
      "gridPos": { "x": 6, "y": 63, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "incident_bot_runbooks_running" }],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Queue Size (Pending + Running)",
      "id": 25,
      "gridPos": { "x": 12, "y": 63, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "incident_bot_runbooks_pending + incident_bot_runbooks_running" }],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Oldest Pending Age (s)",
      "id": 26,
      "gridPos": { "x": 18, "y": 63, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "incident_bot_runbooks_pending_oldest_seconds" }],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Stale Pending (>= 6h)",
      "id": 27,
      "gridPos": { "x": 0, "y": 67, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "max(incident_bot_runbooks_pending_stale_total{threshold=\"21600\"}) or vector(0)"}],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Runbook Failures (final) last 15m",
      "id": 28,
      "gridPos": { "x": 6, "y": 67, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(increase(incident_bot_runbooks_failed_total[15m]))" }],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "Runbook Failures / min (final, 5m rate)",
      "id": 29,
      "gridPos": { "x": 12, "y": 67, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (runbook, reason) (rate(incident_bot_runbooks_failed_total[5m])) * 60",
          "legendFormat": "{{runbook}} / {{reason}}"
        }
      ],
      "options": {
        "legend": { "showLegend": true, "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "timeseries",
      "title": "Confirmation Latency (p50 / p95, 15m window)",
      "id": 30,
      "gridPos": { "x": 0, "y": 74, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(incident_bot_runbook_confirmation_latency_seconds_bucket[15m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(incident_bot_runbook_confirmation_latency_seconds_bucket[15m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {
        "legend": { "showLegend": true, "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    }
  ]
}